# CachyOS kernel config for npkg distro
# Base: x86_64 defconfig + CachyOS tuning
# Generated as a starting point — run `make menuconfig` to customize

CONFIG_LOCALVERSION="-cachyos"
CONFIG_LOCALVERSION_AUTO=n

# Scheduler
CONFIG_SCHED_BORE=y
CONFIG_SCHED_CLASS_EXT=y
CONFIG_PREEMPT=y
CONFIG_PREEMPT_VOLUNTARY=n
CONFIG_HZ_300=y
CONFIG_HZ=300

# Memory
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y

# CPU
CONFIG_GENERIC_CPU=y
CONFIG_X86_64=y
CONFIG_64BIT=y

# Compression
CONFIG_KERNEL_ZSTD=y
CONFIG_MODULE_COMPRESS_ZSTD=y

# Module versioning (required for Module.symvers / DKMS)
CONFIG_MODULES=y
CONFIG_MODVERSIONS=y

# Security
CONFIG_SECURITY=y
CONFIG_SECURITY_SELINUX=n
CONFIG_SECURITY_APPARMOR=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_BTRFS_FS=y
CONFIG_XFS_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_VFAT_FS=y
CONFIG_EXFAT_FS=y
CONFIG_NTFS3_FS=y

# Networking
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_NETFILTER=y
CONFIG_NF_TABLES=y

# Virtio (for VM/QEMU support)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y

# USB
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_STORAGE=y

# Sound
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_HDA_INTEL=y

# Graphics
CONFIG_DRM=y
CONFIG_DRM_I915=y
CONFIG_DRM_AMDGPU=y
CONFIG_DRM_NOUVEAU=y

# Initramfs
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
